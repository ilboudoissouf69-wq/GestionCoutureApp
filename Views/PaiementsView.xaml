<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="GestionCoutureApp.Views.PaiementsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="28,24,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- BANDEAU OPERATEUR -->
        <Border Grid.Row="0"
                CornerRadius="8"
                Padding="14,10"
                Margin="0,0,0,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0"
                        EndPoint="1,0">
                    <GradientStop Color="#1E3A5F"
                            Offset="0"/>
                    <GradientStop Color="#0D9488"
                            Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Gestion des Paiements"
                           FontSize="20"
                        FontWeight="Bold"
                           Foreground="White"
                        VerticalAlignment="Center"/>
                <Border Grid.Column="1"
                        CornerRadius="14"
                        Padding="10,4"
                        Background="#1A5C50">
                    <TextBlock x:Name="TxtOperateurConnecte"
                               Text="Operateur : -"
                               FontSize="12"
                            FontWeight="SemiBold"
                               Foreground="White"/>
                </Border>
            </Grid>
        </Border>

        <!-- CORPS -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="370"/>
            </Grid.ColumnDefinitions>

            <!-- GAUCHE : Tableau -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource Card}"
                        Padding="0">
                    <DataGrid x:Name="GridPaiements"
                              Style="{StaticResource ModernGrid}"
                              SelectionChanged="GridPaiements_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="N. Recu"
                                                Binding="{Binding RecuNumero}"
                                    Width="155"/>
                            <DataGridTextColumn Header="Client"
                                                Binding="{Binding Commande.Client.Nom}"
                                    Width="*"/>
                            <DataGridTextColumn Header="Montant (FCFA)"
                                                Binding="{Binding MontantPaye, StringFormat={}{0:N0}}"
                                    Width="120"/>
                            <DataGridTextColumn Header="Mode"
                                                Binding="{Binding ModePaiement}"
                                    Width="110"/>
                            <DataGridTextColumn Header="Operateur"
                                                Binding="{Binding NomOperateur}"
                                    Width="130"/>
                            <DataGridTextColumn Header="Date / Heure"
                                                Binding="{Binding DatePaiement, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                    Width="130"/>
                            <DataGridTemplateColumn Header="Statut"
                                    Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12"
                                                Padding="8,3"
                                                HorizontalAlignment="Center"
                                                Margin="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"
                                                            Value="#DCFCE7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EstAnnule}"
                                                                Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatutAffichage}"
                                                       FontSize="11"
                                                    FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground"
                                                                Value="#059669"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EstAnnule}"
                                                                    Value="True">
                                                                <Setter Property="Foreground"
                                                                        Value="#DC2626"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,12,0,0">
                    <Button x:Name="BtnGenererRecu"
                            Content="Imprimer le recu"
                            Style="{StaticResource BtnNavy}"
                            Height="38"
                            Padding="16,0"
                            Click="BtnGenererRecu_Click"
                            Margin="0,0,10,0"/>
                    <Button x:Name="BtnAnnuler"
                            Content="Annuler ce paiement"
                            Style="{StaticResource BtnDanger}"
                            Height="38"
                            Padding="16,0"
                            Click="BtnAnnuler_Click"/>
                </StackPanel>
            </Grid>

            <!-- DROITE : Formulaire -->
            <Border Grid.Column="2"
                    Style="{StaticResource Card}"
                    Padding="0"
                    VerticalAlignment="Top">
                <StackPanel>
                    <Border CornerRadius="10,10,0,0"
                            Padding="20,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                    EndPoint="1,0">
                                <GradientStop Color="#1E3A5F"
                                        Offset="0"/>
                                <GradientStop Color="#0D9488"
                                        Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="Enregistrer un paiement"
                                   FontSize="14"
                                FontWeight="Bold"
                                Foreground="White"/>
                    </Border>

                    <StackPanel Margin="20,16,20,20">

                        <TextBlock Text="Commande *"
                                Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbCommande"
                                  Style="{StaticResource ModernComboBox}"
                                  DisplayMemberPath="DisplayText"
                                  Margin="0,0,0,14"
                                  SelectionChanged="CmbCommande_SelectionChanged"/>

                        <!-- Resume commande -->
                        <Border CornerRadius="8"
                                Padding="14,12"
                                Margin="0,0,0,16"
                                Background="#F0FDF9"
                                BorderBrush="#CCFBF1"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="TxtInfoClient"
                                           Text="Client : -"
                                           FontSize="13"
                                        FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                                <Separator Background="#CCFBF1"
                                        Margin="0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="TOTAL"
                                                FontSize="10"
                                                   FontWeight="Bold"
                                                Foreground="#64748B"/>
                                        <TextBlock x:Name="TxtInfoMontant"
                                                Text="- FCFA"
                                                   FontSize="15"
                                                FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="RESTE"
                                                FontSize="10"
                                                   FontWeight="Bold"
                                                Foreground="#64748B"/>
                                        <TextBlock x:Name="TxtInfoReste"
                                                Text="- FCFA"
                                                   FontSize="15"
                                                FontWeight="Bold"
                                                   Foreground="{StaticResource DangerBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="TxtInfoDejaPaye"
                                           Text="Deja paye : 0 FCFA"
                                           FontSize="12"
                                           Foreground="{StaticResource SuccessBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Montant du paiement (FCFA) *"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtMontant"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Mode de paiement"
                                   Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbModePaiement"
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,20"
                                SelectedIndex="0">
                            <ComboBoxItem Content="Especes"/>
                            <ComboBoxItem Content="Mobile Money"/>
                            <ComboBoxItem Content="Virement"/>
                            <ComboBoxItem Content="Cheque"/>
                        </ComboBox>

                        <Button x:Name="BtnEnregistrer"
                                Content="Enregistrer le paiement"
                                Style="{StaticResource BtnSuccess}"
                                Height="42"
                                FontSize="13"
                                FontWeight="Bold"
                                Click="BtnEnregistrer_Click"
                                Margin="0,0,0,16"/>

                        <Separator Background="{StaticResource BorderBrush}"
                                Margin="0,0,0,12"/>

                        <TextBlock Text="Historique des paiements"
                                   FontSize="13"
                                FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,8"/>
                        <Border BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7">
                            <ListBox x:Name="ListeHistorique"
                                     MaxHeight="160"
                                    FontSize="11"
                                     FontFamily="Consolas"
                                     BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"
                                                Value="10,7"/>
                                        <Setter Property="BorderBrush"
                                                Value="{StaticResource BorderBrush}"/>
                                        <Setter Property="BorderThickness"
                                                Value="0,0,0,1"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>

                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
