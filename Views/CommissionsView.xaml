<Page x:Class="GestionCoutureApp.Views.CommissionsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">

            <TextBlock Text="Commissions des Couturiers"
                       FontSize="22"
                    FontWeight="Bold"
                       Foreground="#1E3A5F"
                    Margin="0,0,0,20"/>

            <!-- Parametres -->
            <Border Background="White"
                    CornerRadius="8"
                    Padding="20"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Parametres de calcul"
                               FontSize="14"
                            FontWeight="Bold"
                               Foreground="#1E3A5F"
                            Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Commission (%)"
                                    FontSize="12"
                                       Foreground="#7F8C8D"
                                    Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtPourcentage"
                                    Text="40"
                                     Height="38"
                                    FontSize="13"
                                     VerticalContentAlignment="Center"
                                     Padding="8,0,8,0"
                                    BorderBrush="#D5D8DC"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Date debut"
                                    FontSize="12"
                                       Foreground="#7F8C8D"
                                    Margin="0,0,0,4"/>
                            <DatePicker x:Name="DateDebut"
                                    Height="38"
                                        FontSize="13"
                                    BorderBrush="#D5D8DC"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Date fin"
                                    FontSize="12"
                                       Foreground="#7F8C8D"
                                    Margin="0,0,0,4"/>
                            <DatePicker x:Name="DateFin"
                                    Height="38"
                                        FontSize="13"
                                    BorderBrush="#D5D8DC"/>
                        </StackPanel>

                        <Button Grid.Column="6"
                                Content="Calculer"
                                Height="38"
                                FontSize="13"
                                FontWeight="Bold"
                                Foreground="White"
                                Background="#2E86C1"
                                BorderThickness="0"
                                Cursor="Hand"
                                VerticalAlignment="Bottom"
                                Click="BtnCalculer_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius"
                                            Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Filtre couturier -->
            <Border Background="White"
                    CornerRadius="8"
                    Padding="20"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Filtrer par couturier (optionnel)"
                               FontSize="14"
                            FontWeight="Bold"
                               Foreground="#1E3A5F"
                            Margin="0,0,0,10"/>
                    <ComboBox x:Name="CmbCouturier"
                            Height="36"
                            FontSize="13"
                              Padding="8,0,8,0"
                            BorderBrush="#D5D8DC"
                              SelectionChanged="CmbCouturier_SelectionChanged"/>
                </StackPanel>
            </Border>

            <!-- Cartes stats -->
            <UniformGrid Columns="3"
                    Margin="0,0,0,20">
                <Border Background="#3498DB"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="CA TOTAL"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="#D6EAF8"/>
                        <TextBlock x:Name="TxtCaTotal"
                                Text="0"
                                FontSize="26"
                                FontWeight="Bold"
                                   Foreground="White"
                                Margin="0,4,0,2"/>
                        <TextBlock Text="FCFA"
                                FontSize="11"
                                Foreground="#D6EAF8"/>
                    </StackPanel>
                </Border>
                <Border Background="#E67E22"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="COMMISSIONS"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="#FDEBD0"/>
                        <TextBlock x:Name="TxtTotalCommissions"
                                Text="0"
                                FontSize="26"
                                FontWeight="Bold"
                                   Foreground="White"
                                Margin="0,4,0,2"/>
                        <TextBlock Text="FCFA a reverser"
                                FontSize="11"
                                Foreground="#FDEBD0"/>
                    </StackPanel>
                </Border>
                <Border Background="#2ECC71"
                        CornerRadius="8"
                        Padding="15">
                    <StackPanel>
                        <TextBlock Text="RESTE ATELIER"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="#D5F5E3"/>
                        <TextBlock x:Name="TxtResteAtelier"
                                Text="0"
                                FontSize="26"
                                FontWeight="Bold"
                                   Foreground="White"
                                Margin="0,4,0,2"/>
                        <TextBlock Text="FCFA pour l'atelier"
                                FontSize="11"
                                Foreground="#D5F5E3"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Detail par couturier -->
            <Border Background="White"
                    CornerRadius="8"
                    Padding="20"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Detail par Couturier"
                               FontSize="14"
                            FontWeight="Bold"
                               Foreground="#1E3A5F"
                            Margin="0,0,0,10"/>
                    <DataGrid x:Name="GridCommissions"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"
                              AlternatingRowBackground="#F8F9FA"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Couturier"
                                                Binding="{Binding Nom}"
                                    Width="*"/>
                            <DataGridTextColumn Header="Commandes terminees"
                                                Binding="{Binding NbCommandes}"
                                    Width="160"/>
                            <DataGridTextColumn Header="CA (FCFA)"
                                                Binding="{Binding CaTotal}"
                                    Width="130"/>
                            <DataGridTextColumn Header="Commission (FCFA)"
                                                Binding="{Binding Commission}"
                                    Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>