<Window x:Class="GestionCoutureApp.Views.WebcamCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capturer une photo"
        Width="640"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#2C3E50">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="Black"
                CornerRadius="6"
                Grid.Row="0">
            <Image x:Name="WebcamPreview"
                   Stretch="Uniform"/>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,15,0,0">
            <Button x:Name="BtnDemarrer"
                    Content="Demarrer la camera"
                    Width="160"
                    Height="38"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="#27AE60"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnDemarrer_Click"
                    Margin="0,0,10,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius"
                                Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="BtnCapturer"
                    Content="Capturer"
                    Width="120"
                    Height="38"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="#2E86C1"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnCapturer_Click"
                    IsEnabled="False"
                    Margin="0,0,10,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius"
                                Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="BtnAnnuler"
                    Content="Annuler"
                    Width="100"
                    Height="38"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="#95A5A6"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnAnnuler_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius"
                                Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
