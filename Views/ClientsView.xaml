<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="GestionCoutureApp.Views.ClientsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="28,24,28,28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- GAUCHE -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Titre avec trait rouge -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Gestion des Clients"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <Border Height="3" Width="40" CornerRadius="2"
                        Background="#CC0000" HorizontalAlignment="Left"
                        Margin="0,6,0,0"/>
            </StackPanel>

            <TextBox Grid.Row="1" x:Name="TxtRecherche"
                     Style="{StaticResource ModernTextBox}"
                     Margin="0,0,0,14"
                     TextChanged="TxtRecherche_TextChanged"/>

            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                <DataGrid x:Name="GridClients"
                          Style="{StaticResource ModernGrid}"
                          SelectionChanged="GridClients_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nom"       Binding="{Binding Nom}"       Width="*"/>
                        <DataGridTextColumn Header="Prenom"    Binding="{Binding Prenom}"    Width="*"/>
                        <DataGridTextColumn Header="Telephone" Binding="{Binding Telephone}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- DROITE -->
        <Border Grid.Column="2" Style="{StaticResource Card}"
                Padding="0" VerticalAlignment="Top">
            <StackPanel>
                <!-- En-tête panel — noir -->
                <Border CornerRadius="10,10,0,0" Padding="20,14"
                        Background="#1A1A1A">
                    <TextBlock Text="Details du client"
                               FontSize="14" FontWeight="Bold" Foreground="White"/>
                </Border>

                <StackPanel Margin="20,16,20,20">
                    <TextBlock Text="Nom *" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtNom" Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Prenom *" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtPrenom" Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Telephone" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtTelephone" Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,22"/>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>

                    <Button Content="Ajouter"      Style="{StaticResource BtnSuccess}" Click="BtnAjouter_Click"  Margin="0,0,0,8"/>
                    <Button Content="Modifier"     Style="{StaticResource BtnNavy}"   Click="BtnModifier_Click" Margin="0,0,0,8"/>
                    <Button Content="Supprimer"    Style="{StaticResource BtnDanger}" Click="BtnSupprimer_Click" Margin="0,0,0,8"/>
                    <Button Content="Vider les champs" Style="{StaticResource BtnGhost}" Click="BtnVider_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
