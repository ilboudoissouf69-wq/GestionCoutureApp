<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="GestionCoutureApp.Views.CouturierDashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">

            <!-- ══════════════════════════ EN-TÊTE COUTURIER ═════════════════ -->
            <Border CornerRadius="12"
                    Padding="28,22"
                    Margin="0,0,0,24"
                    Background="#1A1A1A">

                <!-- Accent rouge sur le bord supérieur -->
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#CC0000" Offset="0"/>
                        <GradientStop Color="#660000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>0,3,0,0</Border.BorderThickness>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Mon Espace Couturier"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <Border Height="2" Width="40" CornerRadius="1"
                                Background="#CC0000"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"/>
                        <TextBlock x:Name="TxtNomCouturier"
                                   FontSize="14"
                                   Foreground="#B0A8A4"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Logo couturier -->
                    <Border Grid.Column="1"
                            Width="72" Height="72"
                            CornerRadius="10"
                            Background="#2A2A2A"
                            VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Resources/logo_retouche_choco.png"
                               Width="60" Height="60"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="Uniform"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════════════════════ 4 CARTES ══════════════════════════ -->
            <UniformGrid Columns="4" Margin="0,0,0,22">

                <!-- En cours — rouge marque -->
                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="EN COURS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtEnCours" Text="0"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="#CC0000"
                                   Margin="0,4,0,2"/>
                        <TextBlock Text="commandes actives"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Terminées — vert -->
                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="TERMINEES"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtTerminees" Text="0"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"
                                   Margin="0,4,0,2"/>
                        <TextBlock Text="pretes a livrer"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Livrées — orange -->
                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="LIVREES"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtLivrees" Text="0"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}"
                                   Margin="0,4,0,2"/>
                        <TextBlock Text="au client"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Revenus — noir charbon -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="REVENUS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtRevenus" Text="0"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,4,0,2"/>
                        <TextBlock Text="FCFA generes"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ══════════════════════════ TABLEAU COMMANDES ═════════════════ -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Mes commandes assignees"
                               Style="{StaticResource CardTitle}"/>
                    <DataGrid x:Name="GridMesCommandes"
                              Style="{StaticResource ModernGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Client"       Binding="{Binding Client.Nom}"                                     Width="*"/>
                            <DataGridTextColumn Header="Type"         Binding="{Binding TypeVetement}"                                   Width="*"/>
                            <DataGridTextColumn Header="Description"  Binding="{Binding DescriptionPrecision}"                           Width="*"/>
                            <DataGridTextColumn Header="Statut"       Binding="{Binding Statut}"                                         Width="100"/>
                            <DataGridTextColumn Header="Montant"      Binding="{Binding MontantTotal, StringFormat={}{0:N0}}"             Width="110"/>
                            <DataGridTextColumn Header="Date fin"     Binding="{Binding DateFin, StringFormat={}{0:dd/MM/yyyy}}"         Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
