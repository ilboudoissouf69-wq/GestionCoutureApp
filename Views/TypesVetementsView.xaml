<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="GestionCoutureApp.Views.TypesVetementsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="28,24,28,28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- GAUCHE -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Types de Vetements"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <Border Height="3" Width="40" CornerRadius="2"
                        Background="#CC0000" HorizontalAlignment="Left"
                        Margin="0,6,0,0"/>
            </StackPanel>

            <TextBox Grid.Row="1" x:Name="TxtRecherche"
                     Style="{StaticResource ModernTextBox}"
                     Margin="0,0,0,14"
                     TextChanged="TxtRecherche_TextChanged"/>

            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                <DataGrid x:Name="GridTypes"
                          Style="{StaticResource ModernGrid}"
                          SelectionChanged="GridTypes_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nom du type"         Binding="{Binding Nom}"       Width="*"/>
                        <DataGridTextColumn Header="Prix de base (FCFA)" Binding="{Binding PrixBase}"  Width="160"/>
                        <DataGridTextColumn Header="Nb mesures"          Binding="{Binding NbMesures}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- DROITE -->
        <Border Grid.Column="2" Style="{StaticResource Card}"
                Padding="0" VerticalAlignment="Top">
            <StackPanel>
                <!-- En-tête panel — noir -->
                <Border CornerRadius="10,10,0,0" Padding="20,14"
                        Background="#1A1A1A">
                    <TextBlock Text="Details du type"
                               FontSize="14" FontWeight="Bold" Foreground="White"/>
                </Border>

                <StackPanel Margin="20,16,20,20">
                    <TextBlock Text="Nom *"                Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtNom"               Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                    <TextBlock Text="Prix de base (FCFA) *" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtPrixBase"           Style="{StaticResource ModernTextBox}" Margin="0,0,0,18"/>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,14"/>

                    <TextBlock Text="Mesures requises"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtNomMesure" Grid.Column="0"
                                 Style="{StaticResource ModernTextBox}" Height="36"/>
                        <Button Grid.Column="2" x:Name="BtnAjouterMesure"
                                Content="+"
                                Style="{StaticResource BtnPrimary}"
                                Height="36" Padding="0"
                                FontSize="18" FontWeight="Bold"
                                Click="BtnAjouterMesure_Click"/>
                    </Grid>

                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="7" Margin="0,0,0,16">
                        <ListBox x:Name="ListeMesures"
                                 MaxHeight="140" BorderThickness="0"
                                 Background="Transparent" FontSize="13">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding"         Value="12,8"/>
                                    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,14"/>

                    <Button Content="Enregistrer" Style="{StaticResource BtnSuccess}" Click="BtnEnregistrer_Click" Margin="0,0,0,8"/>
                    <Button Content="Supprimer"   Style="{StaticResource BtnDanger}"  Click="BtnSupprimer_Click"   Margin="0,0,0,8"/>
                    <Button Content="Vider"       Style="{StaticResource BtnGhost}"   Click="BtnVider_Click"       Margin="0,0,0,8"/>

                    <TextBlock x:Name="TxtMessage" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
