<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="GestionCoutureApp.Views.EmployesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="28,24,28,28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="330"/>
        </Grid.ColumnDefinitions>

        <!-- GAUCHE -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                    Text="Gestion des Employes"
                       Style="{StaticResource SectionTitle}"/>

            <TextBox Grid.Row="1"
                    x:Name="TxtRecherche"
                     Style="{StaticResource ModernTextBox}"
                     Margin="0,0,0,14"
                     TextChanged="TxtRecherche_TextChanged"/>

            <Border Grid.Row="2"
                    Style="{StaticResource Card}"
                    Padding="0">

                <DataGrid x:Name="GridEmployes"
                          Style="{StaticResource ModernGrid}"
                          SelectionChanged="GridEmployes_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nom complet"
                                Binding="{Binding NomComplet}"
                                Width="*"/>
                        <DataGridTextColumn Header="Identifiant"
                                Binding="{Binding Identifiant}"
                                Width="130"/>
                        <DataGridTextColumn Header="Role"
                                Binding="{Binding Role}"
                                Width="110"/>
                        <DataGridTextColumn Header="Statut"
                                Binding="{Binding Statut}"
                                Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- DROITE -->
        <Border Grid.Column="2"
                Style="{StaticResource Card}"
                Padding="0"
                VerticalAlignment="Top">

            <StackPanel>
                <Border CornerRadius="10,10,0,0"
                        Padding="20,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                EndPoint="1,0">
                            <GradientStop Color="#1E3A5F"
                                    Offset="0"/>
                            <GradientStop Color="#0D9488"
                                    Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="Details de l'employe"
                               FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"/>
                </Border>

                <StackPanel Margin="20,16,20,20">
                    <TextBlock Text="Nom *"
                            Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtNom"
                            Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Prenom *"
                            Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtPrenom"
                            Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Identifiant *"
                            Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtIdentifiant"
                            Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Mot de passe *"
                            Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="TxtMotDePasse"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,12"/>

                    <TextBlock Text="Role *"
                            Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CmbRole"
                            Style="{StaticResource ModernComboBox}"
                              Margin="0,0,0,20">
                        <ComboBoxItem Content="Secretaire"/>
                        <ComboBoxItem Content="Couturier"/>
                        <ComboBoxItem Content="Boss"/>
                    </ComboBox>

                    <Separator Background="{StaticResource BorderBrush}"
                            Margin="0,0,0,16"/>

                    <Button Content="Enregistrer"
                            Style="{StaticResource BtnSuccess}"
                            Click="BtnEnregistrer_Click"
                            Margin="0,0,0,8"/>
                    <Button Content="Modifier"
                            Style="{StaticResource BtnNavy}"
                            Click="BtnModifier_Click"
                            Margin="0,0,0,8"/>
                    <Button x:Name="BtnSuspendre"
                            Content="Suspendre"
                            Style="{StaticResource BtnWarning}"
                            Click="BtnSuspendre_Click"
                            Margin="0,0,0,8"/>
                    <Button Content="Vider"
                            Style="{StaticResource BtnGhost}"
                            Click="BtnVider_Click"
                            Margin="0,0,0,8"/>

                    <Border x:Name="BorderMessage"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtMessage"
                                FontSize="12"
                                TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
