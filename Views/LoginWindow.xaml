<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="GestionCoutureApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion Couture"
        Height="520"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="White"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <!-- supprime CardShadow pour eviter le flou -->
    </Window.Resources>

    <Border CornerRadius="0"
            Margin="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0"
                    EndPoint="0,1">
                <GradientStop Color="#FFFFFF"
                        Offset="0"/>
                <GradientStop Color="#F8FAFC"
                        Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- EN-TETE -->
            <Border Grid.Row="0"
                    CornerRadius="14,14,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                            EndPoint="1,1">
                        <GradientStop Color="#1E3A5F"
                                Offset="0"/>
                        <GradientStop Color="#0D9488"
                                Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <Border Width="48"
                            Height="48"
                            CornerRadius="24"
                            Background="#1A5C50"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,8">
                        <TextBlock Text="GC"
                                FontSize="18"
                                FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="GESTION COUTURE"
                               FontSize="18"
                            FontWeight="Bold"
                               Foreground="White"
                            HorizontalAlignment="Center"/>
                    <TextBlock Text="Systeme de gestion d'atelier"
                               FontSize="12"
                            Foreground="#B2D8D0"
                               HorizontalAlignment="Center"
                            Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- BOUTON FERMER -->
            <Button Grid.Row="0"
                    Content="X"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Width="28"
                    Height="28"
                    Margin="0,10,12,0"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnFermer_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                Width="28"
                                Height="28">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="bg"
                                        Property="Background"
                                        Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- FORMULAIRE -->
            <StackPanel Grid.Row="1"
                    Margin="36,28,36,28"
                    VerticalAlignment="Center">

                <TextBlock Text="Identifiant"
                        Style="{StaticResource FieldLabel}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TxtIdentifiant"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="Mot de passe"
                        Style="{StaticResource FieldLabel}"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="TxtPassword"
                             Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,26"/>

                <Button Content="SE CONNECTER"
                        Style="{StaticResource BtnPrimary}"
                        Height="42"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="BtnConnexion_Click"/>

                <TextBlock x:Name="TxtErreur"
                           FontSize="12"
                        Foreground="#DC2626"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                        Margin="0,10,0,0"
                           Visibility="Collapsed"/>

                <TextBlock Text="2026 GestionCouture - Tous droits reserves"
                           FontSize="10"
                        Foreground="#CBD5E1"
                           HorizontalAlignment="Center"
                        Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
