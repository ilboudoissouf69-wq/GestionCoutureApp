<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="GestionCoutureApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Retouche Choco — Connexion"
        Height="540"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A1A"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStyle="SingleBorderWindow">

    <Border>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F7F3F0" Offset="0"/>
                <GradientStop Color="#EFE8E4" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="200"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ──────────── EN-TÊTE : noir + dégradé rouge ──────────── -->
            <Border Grid.Row="0" CornerRadius="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1A1A1A" Offset="0"/>
                        <GradientStop Color="#2D0000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/logo_retouche_choco.png"
                           Width="90"
                           Height="90"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="Uniform"/>
                    <Border Height="2" Width="48" CornerRadius="1"
                            Background="#CC0000"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,8"/>
                    <TextBlock Text="RETOUCHE CHOCO"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               />
                    <TextBlock Text="Systeme de gestion d'atelier"
                               FontSize="11"
                               Foreground="#B0A8A4"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Bouton fermer ── -->
            <Button Grid.Row="0"
                    Content="✕"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Width="28" Height="28"
                    Margin="0,10,12,0"
                    FontSize="12" FontWeight="Bold"
                    Foreground="White"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnFermer_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                Width="28" Height="28">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ──────────── FORMULAIRE ──────────── -->
            <StackPanel Grid.Row="1"
                        Margin="36,28,36,28"
                        VerticalAlignment="Center">

                <TextBlock Text="Identifiant"
                           Style="{StaticResource FieldLabel}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TxtIdentifiant"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="Mot de passe"
                           Style="{StaticResource FieldLabel}"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="TxtPassword"
                             Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,26"/>

                <Button Content="SE CONNECTER"
                        Style="{StaticResource BtnPrimary}"
                        Height="44"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="BtnConnexion_Click"/>

                <TextBlock x:Name="TxtErreur"
                           FontSize="12"
                           Foreground="#CC0000"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           Visibility="Collapsed"/>

                <TextBlock Text="© 2026  Retouche Choco — Ilassa Design"
                           FontSize="10"
                           Foreground="#B0A8A4"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
