<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="GestionCoutureApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion Couture — Retouche Choco"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>

        <!-- ── Bouton nav normal : texte gris clair sur fond noir ── -->
        <Style TargetType="Button" x:Key="NavBtn">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Foreground"               Value="#B0A8A4"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="FontWeight"               Value="Normal"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment"      Value="Stretch"/>
            <Setter Property="Padding"                  Value="20,13"/>
            <Setter Property="Cursor"                   Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="8,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2D2D2D"/>
                                <Setter Property="Foreground"                  Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#CC0000"/>
                                <Setter Property="Foreground"                  Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Bouton nav actif : rouge marque + barre gauche blanche ── -->
        <Style TargetType="Button" x:Key="NavBtnActif" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background"  Value="#CC0000"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="8,1">
                            <Grid>
                                <!-- barre indicatrice gauche -->
                                <Border Width="4"
                                        CornerRadius="2"
                                        Background="White"
                                        HorizontalAlignment="Left"
                                        Margin="-4,6,0,6"/>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#A80000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Séparateur sidebar ── -->
        <Style TargetType="Separator" x:Key="NavSep">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Margin"     Value="16,8"/>
            <Setter Property="Height"     Value="1"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="235"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════ SIDEBAR ═══ -->
        <Border Grid.Column="0" Background="#1A1A1A">

            <DockPanel>

                <!-- Zone logo + identité -->
                <StackPanel DockPanel.Dock="Top"
                            Margin="0,24,0,16"
                            HorizontalAlignment="Center">

                    <!-- Logo sur fond légèrement surélevé -->
                    <Border Width="96"
                            Height="96"
                            CornerRadius="12"
                            Background="#2A2A2A"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                        <Image Source="pack://application:,,,/Resources/logo_retouche_choco.png"
                               Width="84"
                               Height="84"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="Uniform"/>
                    </Border>

                    <!-- Trait rouge sous le logo -->
                    <Border Height="2"
                            Width="48"
                            CornerRadius="1"
                            Background="#CC0000"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,10"/>

                    <TextBlock Text="Retouche Choco"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               />
                    <TextBlock x:Name="TxtUtilisateur"
                               FontSize="11"
                               Foreground="#B0A8A4"
                               HorizontalAlignment="Center"
                               Margin="0,3,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               MaxWidth="200"/>
                </StackPanel>

                <Separator Style="{StaticResource NavSep}" DockPanel.Dock="Top"/>

                <!-- Déconnexion en bas -->
                <Button x:Name="BtnDeconnexion"
                        DockPanel.Dock="Bottom"
                        Content="⏻  Deconnexion"
                        Style="{StaticResource NavBtn}"
                        Foreground="#E57373"
                        Click="BtnDeconnexion_Click"
                        Margin="0,0,0,16"/>

                <Separator Style="{StaticResource NavSep}" DockPanel.Dock="Bottom"/>

                <!-- Menus de navigation -->
                <StackPanel>
                    <Button x:Name="BtnTableauDeBord"
                            Content="  Tableau de bord"
                            Style="{StaticResource NavBtn}"
                            Click="BtnTableauDeBord_Click"/>
                    <Button x:Name="BtnClients"
                            Content="  Clients"
                            Style="{StaticResource NavBtn}"
                            Click="BtnClients_Click"/>
                    <Button x:Name="BtnCommandes"
                            Content="  Commandes"
                            Style="{StaticResource NavBtn}"
                            Click="BtnCommandes_Click"/>
                    <Button x:Name="BtnPaiements"
                            Content="  Paiements"
                            Style="{StaticResource NavBtn}"
                            Click="BtnPaiements_Click"/>

                    <Separator Style="{StaticResource NavSep}"/>

                    <Button x:Name="BtnTypesVetements"
                            Content="  Types vetements"
                            Style="{StaticResource NavBtn}"
                            Visibility="Collapsed"
                            Click="BtnTypesVetements_Click"/>
                    <Button x:Name="BtnEmployes"
                            Content="  Employes"
                            Style="{StaticResource NavBtn}"
                            Visibility="Collapsed"
                            Click="BtnEmployes_Click"/>
                    <Button x:Name="BtnCommissions"
                            Content="  Commissions"
                            Style="{StaticResource NavBtn}"
                            Visibility="Collapsed"
                            Click="BtnCommissions_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════ ZONE CONTENU ═══ -->
        <Frame x:Name="ContentFrame"
               Grid.Column="1"
               Background="{StaticResource BackgroundBrush}"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
