<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="GestionCoutureApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion Couture"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <Style TargetType="Button" x:Key="NavBtn">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Foreground"              Value="#94B4D4"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="FontWeight"              Value="Normal"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment"     Value="Stretch"/>
            <Setter Property="Padding"                 Value="20,13"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="8,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1A4A7A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#0D9488"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator" x:Key="NavSep">
            <Setter Property="Background"  Value="#2A4F7A"/>
            <Setter Property="Margin"      Value="16,8"/>
            <Setter Property="Height"      Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#152D4A" Offset="0"/>
                    <GradientStop Color="#1E3A5F" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="0,28,0,20"
                            HorizontalAlignment="Center">
                    <Border Width="52" Height="52" CornerRadius="26"
                            HorizontalAlignment="Center" Margin="0,0,0,10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0D9488" Offset="0"/>
                                <GradientStop Color="#1E3A5F" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="GC" FontSize="18" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Gestion Couture"
                               FontSize="15" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtUtilisateur"
                               FontSize="11" Foreground="#7FB3D3"
                               HorizontalAlignment="Center" Margin="0,3,0,0"
                               TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="200"/>
                </StackPanel>

                <Separator Style="{StaticResource NavSep}" DockPanel.Dock="Top"/>

                <!-- Deconnexion en bas -->
                <Button x:Name="BtnDeconnexion" DockPanel.Dock="Bottom"
                        Content="Deconnexion"
                        Style="{StaticResource NavBtn}"
                        Foreground="#FC8181"
                        Click="BtnDeconnexion_Click"
                        Margin="0,0,0,16"/>

                <Separator Style="{StaticResource NavSep}" DockPanel.Dock="Bottom"/>

                <!-- Menus -->
                <StackPanel>
                    <Button x:Name="BtnTableauDeBord"
                            Content="Tableau de bord"
                            Style="{StaticResource NavBtn}"
                            Click="BtnTableauDeBord_Click"/>
                    <Button x:Name="BtnClients"
                            Content="Clients"
                            Style="{StaticResource NavBtn}"
                            Click="BtnClients_Click"/>
                    <Button x:Name="BtnCommandes"
                            Content="Commandes"
                            Style="{StaticResource NavBtn}"
                            Click="BtnCommandes_Click"/>
                    <Button x:Name="BtnPaiements"
                            Content="Paiements"
                            Style="{StaticResource NavBtn}"
                            Click="BtnPaiements_Click"/>

                    <Separator Style="{StaticResource NavSep}"/>

                    <Button x:Name="BtnTypesVetements"
                            Content="Types vetements"
                            Style="{StaticResource NavBtn}"
                            Visibility="Collapsed"
                            Click="BtnTypesVetements_Click"/>
                    <Button x:Name="BtnEmployes"
                            Content="Employes"
                            Style="{StaticResource NavBtn}"
                            Visibility="Collapsed"
                            Click="BtnEmployes_Click"/>
                    <Button x:Name="BtnCommissions"
                            Content="Commissions"
                            Style="{StaticResource NavBtn}"
                            Visibility="Collapsed"
                            Click="BtnCommissions_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ZONE CONTENU -->
        <Frame x:Name="ContentFrame"
               Grid.Column="1"
               Background="{StaticResource BackgroundBrush}"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
