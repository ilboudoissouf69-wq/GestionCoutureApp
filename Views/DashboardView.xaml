<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="GestionCoutureApp.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">

            <!-- ══════════════════════════ EN-TÊTE ══════════════════════════ -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Tableau de Bord"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <!-- Trait rouge sous le titre -->
                    <Border Height="3" Width="48" CornerRadius="2"
                            Background="#CC0000"
                            HorizontalAlignment="Left"
                            Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Badge bienvenue — noir charbon -->
                <Border Grid.Column="1"
                        CornerRadius="8"
                        Padding="16,10"
                        VerticalAlignment="Center"
                        Background="#1A1A1A">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="#CC0000"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtBienvenue"
                                   Text="Bienvenue Boss !"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════════════════════ 4 CARTES STATS ════════════════════ -->
            <UniformGrid Columns="4" Margin="0,0,0,22">

                <!-- Clients -->
                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CLIENTS"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TxtTotalClients" Text="0"
                                       FontSize="34" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="Total enregistres"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <!-- Pastille rouge -->
                        <Border Grid.Column="1"
                                Width="44" Height="44" CornerRadius="22"
                                Background="#FCEAEA"
                                VerticalAlignment="Center">
                            <TextBlock Text="C"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="#CC0000"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- En cours -->
                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="EN COURS"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TxtCommandesEnCours" Text="0"
                                       FontSize="34" FontWeight="Bold"
                                       Foreground="{StaticResource WarningBrush}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="Commandes actives"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Width="44" Height="44" CornerRadius="22"
                                Background="#FFF8EE"
                                VerticalAlignment="Center">
                            <TextBlock Text="E"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource WarningBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- CA du jour -->
                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CA DU JOUR"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TxtCaJour" Text="0"
                                       FontSize="34" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="FCFA encaisses"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Width="44" Height="44" CornerRadius="22"
                                Background="#EDFAF2"
                                VerticalAlignment="Center">
                            <TextBlock Text="F"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Retards -->
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="RETARDS"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TxtRetards" Text="0"
                                       FontSize="34" FontWeight="Bold"
                                       Foreground="{StaticResource DangerBrush}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="Delais depasses"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Width="44" Height="44" CornerRadius="22"
                                Background="#FCEAEA"
                                VerticalAlignment="Center">
                            <TextBlock Text="!"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource DangerBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- ══════════════════ GRAPHIQUE + COUTURIERS ════════════════════ -->
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Revenus — 7 derniers jours (FCFA)"
                                   Style="{StaticResource CardTitle}"/>
                        <Grid x:Name="GridGraphique" Height="190"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Performance Couturiers"
                                   Style="{StaticResource CardTitle}"/>
                        <DataGrid x:Name="GridCouturiers"
                                  Style="{StaticResource ModernGrid}"
                                  MaxHeight="190">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Couturier"  Binding="{Binding Nom}"          Width="*"/>
                                <DataGridTextColumn Header="Cmd"        Binding="{Binding NbCommandes}"  Width="50"/>
                                <DataGridTextColumn Header="Terminees"  Binding="{Binding NbTerminees}"  Width="72"/>
                                <DataGridTextColumn Header="Retards"    Binding="{Binding NbRetards}"    Width="65"/>
                                <DataGridTextColumn Header="CA (FCFA)"  Binding="{Binding CaTotal}"      Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════════════════ DERNIÈRES COMMANDES ═══════════════════ -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Dernieres Commandes"
                               Style="{StaticResource CardTitle}"/>
                    <DataGrid x:Name="GridDernieresCommandes"
                              Style="{StaticResource ModernGrid}"
                              MaxHeight="260">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Client"    Binding="{Binding Client}"   Width="*"/>
                            <DataGridTextColumn Header="Type"      Binding="{Binding Type}"     Width="120"/>
                            <DataGridTextColumn Header="Montant"   Binding="{Binding Montant}"  Width="110"/>
                            <DataGridTextColumn Header="Statut"    Binding="{Binding Statut}"   Width="110"/>
                            <DataGridTextColumn Header="Date fin"  Binding="{Binding DateFin}"  Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
